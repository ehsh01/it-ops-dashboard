# =============================================================================
# IT Ops Dashboard - Environment Variables
# =============================================================================
# Copy this file to .env (production) or .env.staging (staging) on the server
# and fill in the values.

# --- Required ---

# PostgreSQL connection string
# Production: use your DigitalOcean managed database
# Staging: use a separate database (e.g. it_ops_staging_db)
DATABASE_URL=postgresql://user:password@host:25060/it_ops_dashboard?sslmode=require

# Session signing secret (min 32 chars, use different values for prod vs staging)
SESSION_SECRET=generate-a-random-string-at-least-32-chars

# Server port (DO NOT CHANGE — Nginx proxies depend on these)
# Production: 5003, Staging: 5006
PORT=5003

# --- Optional: Email (Resend) ---

RESEND_API_KEY=
RESEND_FROM_EMAIL=IT Ops Console <noreply@itopsconsole.com>

# Base URL used in email links (defaults to https://itopsconsole.com in production)
APP_URL=https://itopsconsole.com

# --- Optional: Microsoft 365 Integration ---

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# --- Optional: Google Integration (Gmail + Calendar) ---

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
